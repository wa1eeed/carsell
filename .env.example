# ══════════════════════════════════════════════
# CarLink — Environment Variables
# انسخ هذا الملف إلى .env.local وعبّئ القيم
# ══════════════════════════════════════════════

# ─── Database ─────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/carlink"

# ─── Auth ─────────────────────────────────────
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Storage Provider ─────────────────────────
# بدّل هذا السطر فقط للانتقال بين المزودين:
#   r2       ← Cloudflare R2  (الافتراضي — VPS/Coolify)
#   aws      ← AWS S3
#   alibaba  ← Alibaba Cloud OSS
STORAGE_PROVIDER=r2

# ─── Cloudflare R2 ────────────────────────────
# فعّل عند: STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=carlink-prod
R2_PUBLIC_DOMAIN=cdn.your-domain.com   # Custom domain اختياري

# ─── AWS S3 ───────────────────────────────────
# فعّل عند: STORAGE_PROVIDER=aws
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=me-south-1                  # Bahrain — أقرب للخليج
AWS_S3_BUCKET=carlink-prod

# ─── Alibaba Cloud OSS ────────────────────────
# فعّل عند: STORAGE_PROVIDER=alibaba
ALI_OSS_ACCESS_KEY_ID=
ALI_OSS_ACCESS_KEY_SECRET=
ALI_OSS_REGION=oss-me-east-1           # Middle East
ALI_OSS_BUCKET=carlink-prod

# ─── App ──────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://carlink.sa
NODE_ENV=development

# ─── VDM (Vehicle Data Management — أبشر) ────
VDM_BASE_URL=https://api.vdm.gov.sa
VDM_CLIENT_ID=
VDM_APP_ID=
VDM_APP_KEY=

# ─── Nafath (نفاذ الوطني — ELM) ───────────────
NAFATH_BASE_URL=https://api.elm.sa/nafath
NAFATH_APP_ID=
NAFATH_APP_KEY=
NAFATH_SERVICE_TYPE=CarLink

# ─── Accidents API (علم — بشر) ────────────────
ACCIDENTS_BASE_URL=https://api.elm.sa/basher
ACCIDENTS_OPERATOR_ID=
ACCIDENTS_CLIENT_KEY=
ACCIDENTS_APP_ID=
ACCIDENTS_APP_KEY=

# ─── Mojaz Partner API (علم) ──────────────────
MOJAZ_BASE_URL=https://api.elm.sa/mojaz
MOJAZ_APP_ID=
MOJAZ_APP_KEY=
MOJAZ_CLIENT_KEY=
