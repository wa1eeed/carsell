# Database
DATABASE_URL=postgresql://user:password@localhost:5432/carlink_dev

# NextAuth
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Storage
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=carlink-dev
R2_PUBLIC_URL=

# App
ROOT_DOMAIN=carlink.sa
NODE_ENV=development
LOG_LEVEL=info

# Nafath OIDC
NAFATH_CLIENT_ID=
NAFATH_CLIENT_SECRET=
NAFATH_ISSUER=

# VDM / Absher
VDM_API_URL=
VDM_API_KEY=

# Feature flags
FEATURE_MARKETPLACE=false
FEATURE_NAFATH=false

# Tap.company (fallback — can be overridden from Super Admin Settings)
TAP_SECRET_KEY=sk_test_...
TAP_PUBLIC_KEY=pk_test_...
TAP_ENV=test
TAP_MERCHANT_ID=

# Cron job secret (used by cleanup endpoint)
CRON_SECRET=generate-with-openssl-rand-hex-32

# Media cleanup default (days after sale/removal before photos are deleted)
MEDIA_DELETE_AFTER_DAYS=30

# Custom domain — DNS targets dealers point their domains at
PLATFORM_IP=76.76.21.21
PLATFORM_CNAME=cname.carlink.sa
