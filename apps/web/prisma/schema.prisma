// ══════════════════════════════════════════════
// CarLink — Prisma Schema (fixed with all back-relations)
// ══════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────

enum Role {
  PLATFORM_ADMIN
  SHOWROOM_OWNER
  SHOWROOM_MANAGER
  SHOWROOM_STAFF
}

enum AccountType {
  INDIVIDUAL
  SHOWROOM
  AGENCY
  COMPANY
}

enum IdType {
  CITIZEN
  RESIDENT
  VISITOR
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  SUSPENDED
}

enum BillingPeriod {
  MONTHLY
  YEARLY
}

enum VatMethod {
  FULL_PRICE
  PROFIT_MARGIN
}

enum BodyType {
  SUV
  SEDAN
  PICKUP
  COUPE
  HATCHBACK
  VAN
  CONVERTIBLE
  WAGON
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  ELECTRIC
}

enum Transmission {
  AUTOMATIC
  MANUAL
}

enum CarType {
  NEW
  USED
  USED_QUALIFIED
}

enum CarStatus {
  DRAFT
  FOR_SALE
  AUCTION
  RESERVED
  SOLD
}

enum DisplayMode {
  FIXED_PRICE
  SOUM
  AUCTION
}

enum PlateType {
  PRIVATE
  TAXI
  TRANSPORT
  DIPLOMAT
}

enum DocumentType {
  INSPECTION
  PURCHASE_INVOICE
  INSURANCE
  REGISTRATION
  PREVIOUS_INVOICE
  OTHER
}

enum TimelineEventType {
  CAR_CREATED
  FIELD_UPDATED
  STATUS_CHANGED
  FILE_UPLOADED
  FILE_DELETED
  SALE_REGISTERED
  PRICE_CHANGED
  NOTE_ADDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  FINANCING
  TRADE_IN
  MIXED
}

enum CarDataSource {
  MANUAL
  VDM_VIN
  VDM_ABSHER
}

enum KycStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum AuctionType {
  NONE
  PUBLIC
  PRIVATE
  SOUM
}

enum TradeInCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
}

enum ExpenseCategory {
  RENT
  SALARY
  UTILITIES
  MARKETING
  MAINTENANCE
  INSURANCE
  OTHER
}

enum SupplierType {
  INDIVIDUAL
  AUCTION
  DEALER
  AGENCY
}

enum ProviderType {
  WORKSHOP_FIXED
  WORKSHOP_MOBILE
  INSPECTION_CENTER
  TRANSPORT
  FINANCING_PROVIDER
}

// ─── Platform / Tenants ───────────────────────

model Showroom {
  id                      String             @id @default(uuid())
  // ── Human-readable platform-wide number ──────
  // Auto-assigned at creation: 1001, 1002, ...
  // Displayed as "CL-1001" in UI and admin
  showroomNumber          Int?               @unique
  // ── Public URL handle ────────────────────────
  // Used for: carlink.sa/{slug}  AND  {slug}.carlink.sa
  slug                    String?            @unique
  // ── Custom domain (dealer's own domain) ──────
  // e.g. "mydealership.com" → resolves to this showroom's storefront
  customDomain            String?            @unique
  customDomainVerified    Boolean            @default(false)
  // DNS TXT verification token: carlink-verify={token}
  customDomainToken       String?
  tagline                 String?
  coverImageUrl           String?
  showPrices              Boolean            @default(true)
  phone                   String?
  name                    String
  ownerName               String
  vatNumber               String?
  zatcaRegistered         Boolean            @default(false)
  profitMarginApproved    Boolean            @default(false)
  vatMethod               VatMethod          @default(FULL_PRICE)
  city                    String?
  logoUrl                 String?
  marketplaceEnabled      Boolean            @default(false)
  commissionPct           Decimal?           @db.Decimal(5, 2)
  gatewayAccountId        String?
  gatewayOnboardingStatus String?

  // ── Showroom onboarding info ─────────────────
  activityType          String?   // showroom | agency | hall
  district              String?
  whatsapp              String?
  instagramUrl          String?
  commercialReg         String?
  commercialRegDoc      String?   // R2 path
  commercialRegVerified Boolean   @default(false)

  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  users               ShowroomUser[]
  cars                Car[]
  sales               Sale[]
  customers           Customer[]
  paymentTransactions PaymentTransaction[]
  deposits            Deposit[]
  tradeIns            TradeIn[]
  expenses            ShowroomExpense[]
  suppliers           Supplier[]
  serviceRequests     ServiceRequest[]
  subscription        Subscription?
  carRequests         CarRequest[]

  @@map("showrooms")
}

model ShowroomUser {
  id          String      @id @default(uuid())
  showroomId  String
  name        String
  email       String      @unique
  password    String
  phone       String?
  role        Role        @default(SHOWROOM_STAFF)
  accountType AccountType @default(SHOWROOM)
  isActive    Boolean     @default(true)

  // ── Onboarding / profile completion ──────────
  completedSteps  String[] @default([])   // personalInfo | identity | showroomInfo
  city            String?
  dateOfBirth     String?                 // Hijri
  phoneVerified   Boolean  @default(false)
  phoneVerifiedAt DateTime?

  // ── Nafath ───────────────────────────────────
  nationalId       String?   @unique
  idType           IdType?
  idExpiryDate     String?   // Hijri
  nafathVerified   Boolean   @default(false)
  nafathVerifiedAt DateTime?
  nafathRawData    Json?

  // ── KYC (manual) ─────────────────────────────
  kycStatus       KycStatus @default(NONE)
  kycSubmittedAt  DateTime?
  kycApprovedAt   DateTime?
  kycDocFront     String?
  kycDocBack      String?
  kycRejectReason String?

  createdAt   DateTime    @default(now())

  showroom        Showroom          @relation(fields: [showroomId], references: [id])
  carsCreated     Car[]             @relation("CarCreatedBy")
  timelineEvents  CarTimeline[]
  documentsAdded  CarDocument[]
  salesCreated    Sale[]
  depositsCreated Deposit[]
  expenses        ShowroomExpense[]
  bids            Bid[]

  @@map("showroom_users")
}

// ─── Catalog ──────────────────────────────────

model Brand {
  id       String     @id @default(uuid())
  nameAr   String
  nameEn   String
  logoUrl  String?
  isActive Boolean    @default(true)

  categories Category[]
  cars       Car[]

  @@map("brands")
}

model Category {
  id       String   @id @default(uuid())
  brandId  String
  nameAr   String
  nameEn   String
  bodyType BodyType
  isActive Boolean  @default(true)

  brand  Brand   @relation(fields: [brandId], references: [id])
  models Model[]
  cars   Car[]

  @@map("categories")
}

model Model {
  id         String  @id @default(uuid())
  categoryId String
  name       String
  isActive   Boolean @default(true)

  category Category @relation(fields: [categoryId], references: [id])
  cars     Car[]

  @@map("models")
}

// ─── Inventory ────────────────────────────────

model Car {
  id            String        @id @default(uuid())
  showroomId    String
  brandId       String
  categoryId    String
  modelId       String
  year          Int
  carType       CarType       @default(USED)
  colorExt      String?
  colorInt      String?
  fuelType      FuelType?
  transmission  Transmission?
  odometer      Int?
  vin           String?
  bodyType      BodyType?
  status        CarStatus     @default(DRAFT)
  displayMode   DisplayMode   @default(FIXED_PRICE)
  purchasePrice Decimal       @db.Decimal(12, 2)
  sellPrice     Decimal?      @db.Decimal(12, 2)
  extraCosts    Decimal       @default(0) @db.Decimal(12, 2)
  plateNumber   String?
  plateType     PlateType?
  notes         String?
  // ── Sequential reference number per showroom ─
  // Auto-assigned: showroom A car #1, showroom B car #1 (independent counters)
  // Displayed as "#47" in inventory lists and sale records
  carRefNumber  Int             @default(0)
  listedOnMarket  Boolean       @default(false)
  dataSource      CarDataSource @default(MANUAL)
  vdmLastSyncAt   DateTime?
  vdmRawData      Json?
  marketPrice     Decimal?      @db.Decimal(12, 2)
  supplierId      String?

  // ── VDM (Absher) external fields ─────────────
  vdmSequenceNumber  String?
  registrationExpiry DateTime?
  inspectionExpiry   DateTime?
  insuranceExpiry    DateTime?
  insuranceCompany   String?
  insurancePolicyNo  String?
  engineSize         String?

  // ── Mojaz report ─────────────────────────────
  mojazRequestId   String?
  mojazLastReportAt DateTime?
  mojazReportUrl   String?
  mojazRawData     Json?
  numberOfOwners   Int?

  // ── Accidents (Najm/Basher) ──────────────────
  accidentsLastCheckAt DateTime?
  accidentsCount       Int?
  accidentsCheckYears  Int?
  accidentsRawData     Json?

  // ── R2 Media cleanup ─────────────────────────
  // mediaScheduledDeleteAt: set when car is sold/removed (now + platform setting days)
  // mediaDeletedAt: set after the cron job actually deletes the files
  mediaScheduledDeleteAt DateTime?
  mediaDeletedAt         DateTime?

  // ── Publish / Auction ────────────────────────
  minAcceptedPrice     Decimal?     @db.Decimal(12, 2)  // secret (SOUM)
  auctionType          AuctionType?
  auctionSlug          String?      @unique
  auctionStartAt       DateTime?
  auctionEndsAt        DateTime?
  auctionOpeningPrice  Decimal?     @db.Decimal(12, 2)
  auctionBuyNowPrice   Decimal?     @db.Decimal(12, 2)
  auctionDepositAmount Decimal?     @db.Decimal(10, 2)

  createdBy     String
  deletedAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  showroom        Showroom         @relation(fields: [showroomId], references: [id])
  brand           Brand            @relation(fields: [brandId], references: [id])
  category        Category         @relation(fields: [categoryId], references: [id])
  model           Model            @relation(fields: [modelId], references: [id])
  creator         ShowroomUser     @relation("CarCreatedBy", fields: [createdBy], references: [id])
  supplier        Supplier?        @relation(fields: [supplierId], references: [id])
  images          CarImage[]
  documents       CarDocument[]
  expenses        CarExpense[]
  timeline        CarTimeline[]
  sale            Sale?
  deposits        Deposit[]
  bids            Bid[]
  serviceRequests ServiceRequest[]
  requests        CarRequest[]

  // Unique car number within its showroom
  @@unique([showroomId, carRefNumber])
  // ── Performance indexes (hot query paths) ────
  // Inventory list / dashboard: filter by showroom + status, exclude deleted
  @@index([showroomId, status, deletedAt])
  // Public marketplace: browse FOR_SALE/AUCTION cars across showrooms
  @@index([status, deletedAt])
  // Filter by brand/category (marketplace + showroom filters)
  @@index([brandId])
  @@index([categoryId])
  // Media cleanup cron: find cars due for deletion
  @@index([mediaScheduledDeleteAt, mediaDeletedAt])
  @@map("cars")
}

model CarImage {
  id        String   @id @default(uuid())
  carId     String
  url       String
  sortOrder Int      @default(0)
  isCover   Boolean  @default(false)
  createdAt DateTime @default(now())

  car Car @relation(fields: [carId], references: [id])

  // Cars load their images by carId (cover image, gallery)
  @@index([carId])
  @@map("car_images")
}

model CarDocument {
  id         String       @id @default(uuid())
  carId      String
  docType    DocumentType
  fileUrl    String
  fileName   String
  fileSize   Int
  uploadedBy String
  createdAt  DateTime     @default(now())

  car      Car          @relation(fields: [carId], references: [id])
  uploader ShowroomUser @relation(fields: [uploadedBy], references: [id])

  @@index([carId])
  @@map("car_documents")
}

model CarExpense {
  id          String   @id @default(uuid())
  carId       String
  description String
  amount      Decimal  @db.Decimal(10, 2)
  expenseDate DateTime @default(now())

  car Car @relation(fields: [carId], references: [id])

  @@map("car_expenses")
}

model CarTimeline {
  id        String            @id @default(uuid())
  carId     String
  userId    String
  eventType TimelineEventType
  payload   Json
  createdAt DateTime          @default(now())

  car  Car          @relation(fields: [carId], references: [id])
  user ShowroomUser @relation(fields: [userId], references: [id])

  // Timeline tab loads events for a car, newest first
  @@index([carId, createdAt])
  @@map("car_timeline")
}

// ─── Sales ────────────────────────────────────

model Customer {
  id         String  @id @default(uuid())
  showroomId String
  name       String
  phone      String?
  idNumber   String?
  email      String?

  showroom Showroom  @relation(fields: [showroomId], references: [id])
  sales    Sale[]
  deposits Deposit[]

  // Customers list is scoped to a showroom
  @@index([showroomId])
  @@map("customers")
}

model Sale {
  id            String        @id @default(uuid())
  carId         String        @unique
  showroomId    String
  customerId    String
  sellPrice     Decimal       @db.Decimal(12, 2)
  purchasePrice Decimal       @db.Decimal(12, 2)
  extraCosts    Decimal       @db.Decimal(12, 2)
  vatAmount     Decimal       @db.Decimal(10, 2)
  netProfit     Decimal       @db.Decimal(12, 2)
  vatMethodUsed VatMethod
  paymentMethod PaymentMethod @default(CASH)
  notes         String?
  soldAt        DateTime      @default(now())
  createdBy     String

  car                Car                 @relation(fields: [carId], references: [id])
  showroom           Showroom            @relation(fields: [showroomId], references: [id])
  customer           Customer            @relation(fields: [customerId], references: [id])
  creator            ShowroomUser        @relation(fields: [createdBy], references: [id])
  paymentTransaction PaymentTransaction?
  payments           SalePayment[]
  tradeIn            TradeIn?

  // Sales list / reports: scoped to showroom, ordered by date
  @@index([showroomId, soldAt])
  @@map("sales")
}

model PaymentTransaction {
  id            String   @id @default(uuid())
  saleId        String   @unique
  showroomId    String
  buyerName     String
  grossAmount   Decimal  @db.Decimal(12, 2)
  commissionPct Decimal  @db.Decimal(5, 2)
  commissionAmt Decimal  @db.Decimal(10, 2)
  netToShowroom Decimal  @db.Decimal(12, 2)
  gatewayRef    String?
  status        String   @default("held")
  heldAt        DateTime?
  releasedAt    DateTime?
  createdAt     DateTime @default(now())

  sale     Sale     @relation(fields: [saleId], references: [id])
  showroom Showroom @relation(fields: [showroomId], references: [id])

  @@map("payment_transactions")
}

model Deposit {
  id         String   @id @default(uuid())
  carId      String
  showroomId String
  customerId String
  amount     Decimal  @db.Decimal(10, 2)
  status     String   @default("held")
  notes      String?
  saleId     String?
  createdBy  String
  createdAt  DateTime @default(now())

  car      Car          @relation(fields: [carId], references: [id])
  showroom Showroom     @relation(fields: [showroomId], references: [id])
  customer Customer     @relation(fields: [customerId], references: [id])
  creator  ShowroomUser @relation(fields: [createdBy], references: [id])

  @@index([carId])
  @@index([showroomId, status])
  @@map("deposits")
}

model SalePayment {
  id        String        @id @default(uuid())
  saleId    String
  amount    Decimal       @db.Decimal(12, 2)
  method    PaymentMethod
  reference String?
  paidAt    DateTime      @default(now())
  notes     String?

  sale Sale @relation(fields: [saleId], references: [id])

  @@map("sale_payments")
}

model TradeIn {
  id               String           @id @default(uuid())
  saleId           String           @unique
  showroomId       String
  brandId          String?
  categoryId       String?
  modelId          String?
  year             Int?
  colorExt         String?
  odometer         Int?
  vin              String?
  condition        TradeInCondition @default(GOOD)
  estimatedValue   Decimal          @db.Decimal(12, 2)
  agreedValue      Decimal          @db.Decimal(12, 2)
  addedToInventory Boolean          @default(false)
  inventoryCarId   String?
  createdAt        DateTime         @default(now())

  sale     Sale     @relation(fields: [saleId], references: [id])
  showroom Showroom @relation(fields: [showroomId], references: [id])

  @@map("trade_ins")
}

// ─── Platform Config ──────────────────────────

model PlatformConfig {
  id                   String   @id @default("platform")
  defaultCommissionPct Decimal  @default(2.5) @db.Decimal(5, 2)
  minCommissionPct     Decimal  @default(0)   @db.Decimal(5, 2)
  maxCommissionPct     Decimal  @default(10)  @db.Decimal(5, 2)
  vatPct               Decimal  @default(15)  @db.Decimal(5, 2)
  activePaymentGateway String   @default("moyasar")
  updatedAt            DateTime @updatedAt

  @@map("platform_config")
}

// ─── Showroom Expenses ────────────────────────

model ShowroomExpense {
  id          String          @id @default(uuid())
  showroomId  String
  category    ExpenseCategory
  description String
  amount      Decimal         @db.Decimal(12, 2)
  expenseDate DateTime
  receiptUrl  String?
  createdBy   String
  createdAt   DateTime        @default(now())

  showroom Showroom     @relation(fields: [showroomId], references: [id])
  creator  ShowroomUser @relation(fields: [createdBy], references: [id])

  @@index([showroomId, expenseDate])
  @@map("showroom_expenses")
}

// ─── Suppliers ────────────────────────────────

model Supplier {
  id         String       @id @default(uuid())
  showroomId String
  name       String
  type       SupplierType @default(INDIVIDUAL)
  phone      String?
  notes      String?
  createdAt  DateTime     @default(now())

  showroom Showroom @relation(fields: [showroomId], references: [id])
  cars     Car[]

  @@map("suppliers")
}

// ─── Service Providers ────────────────────────

model ServiceProvider {
  id        String       @id @default(uuid())
  name      String
  type      ProviderType
  city      String
  phone     String?
  isActive  Boolean      @default(true)
  rating    Decimal?     @db.Decimal(3, 2)
  createdAt DateTime     @default(now())

  serviceRequests ServiceRequest[]

  @@index([city, type])
  @@map("service_providers")
}

model ServiceRequest {
  id          String   @id @default(uuid())
  carId       String
  showroomId  String
  providerId  String?
  serviceType String
  city        String
  status      String   @default("pending")
  notes       String?
  fee         Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  car      Car              @relation(fields: [carId], references: [id])
  showroom Showroom         @relation(fields: [showroomId], references: [id])
  provider ServiceProvider? @relation(fields: [providerId], references: [id])

  @@map("service_requests")
}

// ─── Wallet ───────────────────────────────────

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id        String   @id @default(uuid())
  walletId  String
  type      String
  amount    Decimal  @db.Decimal(10, 2)
  reference String?
  notes     String?
  createdAt DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
  @@map("wallet_transactions")
}

// ─── Coupons ──────────────────────────────────

model Coupon {
  id        String    @id @default(uuid())
  code      String    @unique
  type      String
  value     Decimal   @db.Decimal(10, 2)
  appliesTo String
  maxUses   Int?
  usedCount Int       @default(0)
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  @@map("coupons")
}

// ─── Pricing Rules ────────────────────────────

model PricingRule {
  id          String   @id @default(uuid())
  key         String   @unique
  labelAr     String
  labelEn     String
  amount      Decimal  @db.Decimal(10, 2)
  type        String
  appliesTo   String
  isActive    Boolean  @default(true)
  vatIncluded Boolean  @default(true)
  updatedAt   DateTime @updatedAt

  @@map("pricing_rules")
}

// ─── Bids ─────────────────────────────────────

model Bid {
  id         String   @id @default(uuid())
  carId      String
  bidderId   String
  showroomId String?
  amount     Decimal  @db.Decimal(12, 2)
  isWinning  Boolean  @default(false)
  createdAt  DateTime @default(now())

  car    Car          @relation(fields: [carId], references: [id])
  bidder ShowroomUser @relation(fields: [bidderId], references: [id])

  @@index([carId, amount])
  @@index([carId, createdAt])
  @@map("bids")
}

// ─── Car Requests (buyer → dealer) ────────────
// Reservation / Soum offer / Purchase request submitted by a buyer on a car.

enum CarRequestType {
  RESERVATION   // حجز السيارة
  SOUM_OFFER    // عرض سعر (مساومة)
  PURCHASE      // طلب شراء
}

enum CarRequestStatus {
  PENDING       // بانتظار رد المعرض
  ACCEPTED      // مقبول
  REJECTED      // مرفوض
  CANCELLED     // ألغاه المشتري
  COMPLETED     // اكتمل (تحوّل لبيع)
}

model CarRequest {
  id          String           @id @default(uuid())
  carId       String
  showroomId  String           // denormalized for fast dealer-scoped queries
  type        CarRequestType
  status      CarRequestStatus @default(PENDING)
  buyerName   String
  buyerPhone  String
  offerAmount Decimal?         @db.Decimal(12, 2)  // for SOUM_OFFER
  message     String?
  dealerNote  String?          // optional note when accepting/rejecting
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  car      Car      @relation(fields: [carId], references: [id])
  showroom Showroom @relation(fields: [showroomId], references: [id])

  // Dealer's requests inbox: scoped to showroom, filter by status, newest first
  @@index([showroomId, status, createdAt])
  @@index([carId])
  @@map("car_requests")
}

// ─── Plans (dynamic, admin-managed) ──────────

model Plan {
  id            String   @id @default(uuid())
  name          String
  nameAr        String
  slug          String   @unique
  description   String?
  descriptionAr String?
  priceMonthly  Decimal  @db.Decimal(10, 2)
  priceYearly   Decimal  @db.Decimal(10, 2)
  maxCars       Int?                         // null = unlimited
  // JSON: { market, auctions, api, reports, support, customShowroom }
  features      Json     @default("{}")
  isActive      Boolean  @default(true)
  isPublic      Boolean  @default(true)      // false = Enterprise (custom)
  isFeatured    Boolean  @default(false)     // "موصى بها" badge
  sortOrder     Int      @default(0)
  trialDays     Int      @default(14)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

// ─── Subscriptions ────────────────────────────

model Subscription {
  id                 String             @id @default(uuid())
  showroomId         String             @unique
  planId             String
  status             SubscriptionStatus @default(TRIAL)
  billingPeriod      BillingPeriod      @default(MONTHLY)
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelledAt        DateTime?
  tapCustomerId      String?
  tapCardId          String?
  autoRenew          Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  showroom Showroom     @relation(fields: [showroomId], references: [id])
  plan     Plan         @relation(fields: [planId], references: [id])
  payments TapPayment[]

  @@map("subscriptions")
}

// ─── Tap Payments ─────────────────────────────

model TapPayment {
  id             String   @id @default(uuid())
  subscriptionId String
  tapChargeId    String   @unique
  amount         Decimal  @db.Decimal(10, 2)
  currency       String   @default("SAR")
  status         String   // INITIATED | CAPTURED | FAILED | REFUNDED
  description    String?
  tapResponse    Json?
  failureReason  String?
  paidAt         DateTime?
  createdAt      DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId, createdAt])
  @@map("tap_payments")
}

// ─── Platform Settings (key-value, admin) ────

model PlatformSetting {
  key       String   @id
  value     String
  isSecret  Boolean  @default(false)
  updatedBy String?
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}
