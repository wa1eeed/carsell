// ══════════════════════════════════════════════
// CarLink — Prisma Schema
// ══════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────

enum Role {
  PLATFORM_ADMIN
  SHOWROOM_OWNER
  SHOWROOM_MANAGER
  SHOWROOM_STAFF
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  SUSPENDED
}

enum BillingPeriod {
  MONTHLY
  YEARLY
}

enum VatMethod {
  FULL_PRICE
  PROFIT_MARGIN
}

enum BodyType {
  SUV
  SEDAN
  PICKUP
  COUPE
  HATCHBACK
  VAN
  CONVERTIBLE
  WAGON
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  ELECTRIC
}

enum Transmission {
  AUTOMATIC
  MANUAL
}

enum CarType {
  NEW
  USED
  USED_QUALIFIED
}

enum CarStatus {
  DRAFT
  FOR_SALE
  AUCTION
  RESERVED
  SOLD
}

enum DisplayMode {
  FIXED_PRICE
  AUCTION
}

enum PlateType {
  PRIVATE
  TAXI
  TRANSPORT
  DIPLOMAT
}

enum DocumentType {
  INSPECTION
  PURCHASE_INVOICE
  INSURANCE
  REGISTRATION
  PREVIOUS_INVOICE
  OTHER
}

enum TimelineEventType {
  CAR_CREATED
  FIELD_UPDATED
  STATUS_CHANGED
  FILE_UPLOADED
  FILE_DELETED
  SALE_REGISTERED
  PRICE_CHANGED
  NOTE_ADDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  FINANCING
  MIXED
}

// ─── Platform / Tenants ───────────────────────

model Showroom {
  id                   String             @id @default(uuid())
  name                 String
  ownerName            String
  vatNumber            String?
  zatcaRegistered      Boolean            @default(false)
  profitMarginApproved Boolean            @default(false)
  vatMethod            VatMethod          @default(FULL_PRICE)
  city                 String?
  logoUrl              String?
  slug                 String?            @unique

  // ── CarLink Market (اختياري) ──────────────────
  // يُفعَّل فقط إذا أراد المعرض عرض سياراته في السوق العام
  marketplaceEnabled        Boolean   @default(false)
  commissionPct             Decimal?  @db.Decimal(5, 2)   // null = يستخدم الافتراضي في platform_config
  gatewayAccountId          String?   // معرّف البائع في بوابة الدفع (Moyasar/PayTabs/Stripe)
  gatewayOnboardingStatus   String?   // pending | active | suspended

  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  users               ShowroomUser[]
  cars                Car[]
  sales               Sale[]
  customers           Customer[]
  paymentTransactions PaymentTransaction[]
  subscription        Subscription?

  @@map("showrooms")
}

model ShowroomUser {
  id         String   @id @default(uuid())
  showroomId String
  name       String
  email      String   @unique
  password   String
  role       Role     @default(SHOWROOM_STAFF)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  showroom       Showroom      @relation(fields: [showroomId], references: [id])
  carsCreated    Car[]         @relation("CarCreatedBy")
  timelineEvents CarTimeline[]
  documentsAdded CarDocument[]
  salesCreated   Sale[]

  @@map("showroom_users")
}

// ─── Catalog (Admin-managed) ──────────────────

model Brand {
  id       String     @id @default(uuid())
  nameAr   String
  nameEn   String
  logoUrl  String?
  isActive Boolean    @default(true)

  categories Category[]
  cars       Car[]

  @@map("brands")
}

model Category {
  id       String   @id @default(uuid())
  brandId  String
  nameAr   String
  nameEn   String
  bodyType BodyType
  isActive Boolean  @default(true)

  brand  Brand   @relation(fields: [brandId], references: [id])
  models Model[]
  cars   Car[]

  @@map("categories")
}

model Model {
  id         String  @id @default(uuid())
  categoryId String
  name       String
  isActive   Boolean @default(true)

  category Category @relation(fields: [categoryId], references: [id])
  cars     Car[]

  @@map("models")
}

// ─── Inventory ────────────────────────────────

model Car {
  id            String        @id @default(uuid())
  showroomId    String
  brandId       String
  categoryId    String
  modelId       String
  year          Int
  carType       CarType       @default(USED)
  colorExt      String?
  colorInt      String?
  fuelType      FuelType?
  transmission  Transmission?
  odometer      Int?
  vin           String?
  bodyType      BodyType?
  status        CarStatus     @default(DRAFT)
  displayMode   DisplayMode   @default(FIXED_PRICE)
  purchasePrice Decimal       @db.Decimal(12, 2)
  sellPrice     Decimal?      @db.Decimal(12, 2)
  extraCosts    Decimal       @default(0) @db.Decimal(12, 2)
  plateNumber   String?
  plateType     PlateType?
  notes         String?

  // ── CarLink Market ───────────────────────────
  listedOnMarket  Boolean   @default(false)   // هل معروضة في السوق العام
  dataSource        CarDataSource  @default(MANUAL)
  vdmLastSyncAt     DateTime?
  vdmRawData        Json?
  marketPrice     Decimal?  @db.Decimal(12, 2) // سعر العرض في السوق (قد يختلف عن sellPrice)

  createdBy     String
  deletedAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  showroom  Showroom     @relation(fields: [showroomId], references: [id])
  brand     Brand        @relation(fields: [brandId], references: [id])
  category  Category     @relation(fields: [categoryId], references: [id])
  model     Model        @relation(fields: [modelId], references: [id])
  creator   ShowroomUser @relation("CarCreatedBy", fields: [createdBy], references: [id])
  images    CarImage[]
  documents CarDocument[]
  expenses  CarExpense[]
  timeline  CarTimeline[]
  sale      Sale?

  @@map("cars")
}

model CarImage {
  id        String   @id @default(uuid())
  carId     String
  url       String
  sortOrder Int      @default(0)
  isCover   Boolean  @default(false)
  createdAt DateTime @default(now())

  car Car @relation(fields: [carId], references: [id])

  @@map("car_images")
}

model CarDocument {
  id         String       @id @default(uuid())
  carId      String
  docType    DocumentType
  fileUrl    String
  fileName   String
  fileSize   Int
  uploadedBy String
  createdAt  DateTime     @default(now())

  car      Car          @relation(fields: [carId], references: [id])
  uploader ShowroomUser @relation(fields: [uploadedBy], references: [id])

  @@map("car_documents")
}

model CarExpense {
  id          String   @id @default(uuid())
  carId       String
  description String
  amount      Decimal  @db.Decimal(10, 2)
  expenseDate DateTime @default(now())

  car Car @relation(fields: [carId], references: [id])

  @@map("car_expenses")
}

model CarTimeline {
  id        String            @id @default(uuid())
  carId     String
  userId    String
  eventType TimelineEventType
  payload   Json
  createdAt DateTime          @default(now())

  car  Car          @relation(fields: [carId], references: [id])
  user ShowroomUser @relation(fields: [userId], references: [id])

  @@map("car_timeline")
}

// ─── Sales ────────────────────────────────────

model Customer {
  id         String  @id @default(uuid())
  showroomId String
  name       String
  phone      String?
  idNumber   String?
  email      String?

  showroom Showroom @relation(fields: [showroomId], references: [id])
  sales    Sale[]

  @@map("customers")
}

model Sale {
  id            String        @id @default(uuid())
  carId         String        @unique
  showroomId    String
  customerId    String
  sellPrice     Decimal       @db.Decimal(12, 2)
  purchasePrice Decimal       @db.Decimal(12, 2)
  extraCosts    Decimal       @db.Decimal(12, 2)
  vatAmount     Decimal       @db.Decimal(10, 2)
  netProfit     Decimal       @db.Decimal(12, 2)
  vatMethodUsed VatMethod
  paymentMethod PaymentMethod @default(CASH)
  notes         String?
  soldAt        DateTime      @default(now())
  createdBy     String

  car      Car          @relation(fields: [carId], references: [id])
  showroom Showroom     @relation(fields: [showroomId], references: [id])
  customer Customer     @relation(fields: [customerId], references: [id])
  creator  ShowroomUser @relation(fields: [createdBy], references: [id])

  @@map("sales")
}

// ─── CarLink Market — Payments ─────────────────
// يُنشأ فقط عند إتمام بيع عبر CarLink Market
// (لا يُستخدم في بيع SaaS العادي حيث المعرض يتعامل مباشرة)

model PaymentTransaction {
  id            String   @id @default(uuid())
  saleId        String   @unique
  showroomId    String
  buyerName     String
  grossAmount   Decimal  @db.Decimal(12, 2)  // المبلغ الكامل من المشتري
  commissionPct Decimal  @db.Decimal(5, 2)   // نسبة عمولة المنصة المطبّقة
  commissionAmt Decimal  @db.Decimal(10, 2)  // قيمة العمولة بالريال
  netToShowroom Decimal  @db.Decimal(12, 2)  // الصافي للمعرض بعد العمولة
  gatewayRef    String?                       // رقم العملية في بوابة الدفع
  // held = الأموال محتجزة، released = حُرِّرت بعد نقل الملكية
  status        String   @default("held")
  heldAt        DateTime?
  releasedAt    DateTime?
  createdAt     DateTime @default(now())

  sale     Sale     @relation(fields: [saleId], references: [id])
  showroom Showroom @relation(fields: [showroomId], references: [id])

  @@map("payment_transactions")
}

// ─── Platform Configuration ───────────────────
// إعدادات المنصة العامة — يديرها Platform Admin
// صف واحد فقط (singleton) — id = "platform"

model PlatformConfig {
  id                    String   @id @default("platform")
  defaultCommissionPct  Decimal  @default(2.5) @db.Decimal(5, 2)
  minCommissionPct      Decimal  @default(0)   @db.Decimal(5, 2)
  maxCommissionPct      Decimal  @default(10)  @db.Decimal(5, 2)
  vatPct                Decimal  @default(15)  @db.Decimal(5, 2)  // نسبة الضريبة (ZATCA)
  activePaymentGateway  String   @default("moyasar")              // moyasar | paytabs | stripe
  updatedAt             DateTime @updatedAt

  @@map("platform_config")
}


// ─── Deposits (العرابين) ──────────────────────

model Deposit {
  id         String   @id @default(uuid())
  carId      String
  showroomId String
  customerId String
  amount     Decimal  @db.Decimal(10, 2)
  // held = محتجز، applied_to_sale = خُصم من البيع، refunded = مُرجَع، forfeited = مُصادَر
  status     String   @default("held")
  notes      String?
  saleId     String?
  createdBy  String
  createdAt  DateTime @default(now())

  car      Car          @relation(fields: [carId], references: [id])
  showroom Showroom     @relation(fields: [showroomId], references: [id])
  customer Customer     @relation(fields: [customerId], references: [id])
  creator  ShowroomUser @relation(fields: [createdBy], references: [id])

  @@index([carId])
  @@index([showroomId, status])
  @@map("deposits")
}

// ─── Sale Payments (دفعات متعددة) ────────────

model SalePayment {
  id        String        @id @default(uuid())
  saleId    String
  amount    Decimal       @db.Decimal(12, 2)
  method    PaymentMethod
  reference String?
  paidAt    DateTime      @default(now())
  notes     String?

  sale Sale @relation(fields: [saleId], references: [id])

  @@map("sale_payments")
}

// ─── Trade-in (صفقات البدل) ───────────────────

enum TradeInCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
}

model TradeIn {
  id                 String            @id @default(uuid())
  saleId             String            @unique
  showroomId         String
  brandId            String?
  categoryId         String?
  modelId            String?
  year               Int?
  colorExt           String?
  odometer           Int?
  vin                String?
  condition          TradeInCondition  @default(GOOD)
  estimatedValue     Decimal           @db.Decimal(12, 2)
  agreedValue        Decimal           @db.Decimal(12, 2)
  addedToInventory   Boolean           @default(false)
  inventoryCarId     String?
  createdAt          DateTime          @default(now())

  sale     Sale     @relation(fields: [saleId], references: [id])
  showroom Showroom @relation(fields: [showroomId], references: [id])

  @@map("trade_ins")
}

// ─── Showroom Expenses (مصروفات التشغيل) ─────

enum ExpenseCategory {
  RENT
  SALARY
  UTILITIES
  MARKETING
  MAINTENANCE
  INSURANCE
  OTHER
}

model ShowroomExpense {
  id          String          @id @default(uuid())
  showroomId  String
  category    ExpenseCategory
  description String
  amount      Decimal         @db.Decimal(12, 2)
  expenseDate DateTime
  receiptUrl  String?
  createdBy   String
  createdAt   DateTime        @default(now())

  showroom Showroom     @relation(fields: [showroomId], references: [id])
  creator  ShowroomUser @relation(fields: [createdBy], references: [id])

  @@index([showroomId, expenseDate])
  @@map("showroom_expenses")
}

// ─── Suppliers (الموردون) ─────────────────────

enum SupplierType {
  INDIVIDUAL
  AUCTION
  DEALER
  AGENCY
}

model Supplier {
  id         String       @id @default(uuid())
  showroomId String
  name       String
  type       SupplierType @default(INDIVIDUAL)
  phone      String?
  notes      String?
  createdAt  DateTime     @default(now())

  showroom Showroom @relation(fields: [showroomId], references: [id])
  cars     Car[]

  @@map("suppliers")
}

// ─── Extended Enums (Phase 1 additions) ──────

enum AccountType {
  AGENCY
  SHOWROOM
  INDIVIDUAL
  COMPANY
}

enum IndividualType {
  CITIZEN
  RESIDENT
  VISITOR
}

enum CompanyType {
  INSURANCE
  BANK
  FINANCING
  OTHER_COMPANY
}

enum ExtendedCarType {
  NEW
  USED
  USED_QUALIFIED
  UNDER_CUSTOMS
}

enum ExtendedPlateType {
  PRIVATE
  TAXI
  TRANSPORT
  DIPLOMAT
  EXPORT
  CUSTOMS_PLATE
}

enum AuctionType {
  NONE
  PUBLIC
  PRIVATE
  SOUM
}

// ─── Wallet ───────────────────────────────────

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id        String   @id @default(uuid())
  walletId  String
  type      String   // topup | deduct | refund
  amount    Decimal  @db.Decimal(10, 2)
  reference String?
  notes     String?
  createdAt DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
  @@map("wallet_transactions")
}

// ─── Coupons ──────────────────────────────────

model Coupon {
  id         String    @id @default(uuid())
  code       String    @unique
  type       String    // percentage | fixed
  value      Decimal   @db.Decimal(10, 2)
  appliesTo  String    // subscription | service | wallet_topup | all
  maxUses    Int?
  usedCount  Int       @default(0)
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())

  @@map("coupons")
}

// ─── Pricing Rules ────────────────────────────
// كل عملية في المنصة لها سعر قابل للتخصيص من الأدمن

model PricingRule {
  id          String   @id @default(uuid())
  key         String   @unique  // 'listing_fee' | 'sale_commission' | ...
  labelAr     String
  labelEn     String
  amount      Decimal  @db.Decimal(10, 2)
  type        String   // fixed | percentage
  appliesTo   String   // showroom | individual | provider | all
  isActive    Boolean  @default(true)
  vatIncluded Boolean  @default(true)
  updatedAt   DateTime @updatedAt

  @@map("pricing_rules")
}

// ─── Service Providers ────────────────────────

enum ProviderType {
  WORKSHOP_FIXED
  WORKSHOP_MOBILE
  INSPECTION_CENTER
  TRANSPORT
  FINANCING_PROVIDER
}

model ServiceProvider {
  id          String       @id @default(uuid())
  name        String
  type        ProviderType
  city        String
  phone       String?
  isActive    Boolean      @default(true)
  rating      Decimal?     @db.Decimal(3, 2)
  createdAt   DateTime     @default(now())

  serviceRequests ServiceRequest[]

  @@index([city, type])
  @@map("service_providers")
}

model ServiceRequest {
  id          String   @id @default(uuid())
  carId       String
  showroomId  String
  providerId  String?
  serviceType String
  city        String
  status      String   @default("pending") // pending | assigned | completed | cancelled
  notes       String?
  fee         Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  car      Car             @relation(fields: [carId], references: [id])
  showroom Showroom        @relation(fields: [showroomId], references: [id])
  provider ServiceProvider? @relation(fields: [providerId], references: [id])

  @@map("service_requests")
}

// ─── VDM Integration ──────────────────────────

enum CarDataSource {
  MANUAL
  VDM_VIN
  VDM_ABSHER
}

// ─── Nafath fields on ShowroomUser ────────────
// يُضاف للـ ShowroomUser عبر migration لاحقاً
// nationalId     String?  @unique
// idType         String?  // citizen | resident | visitor
// nafathVerified Boolean  @default(false)
// nafathVerifiedAt DateTime?

// ─── External Data Fields ─────────────────────
// حقول تُحدَّث من مصادر خارجية: نفاذ، VDM، موجز
// كل مجموعة حقول مُسبَّقة بـ prefix يدل على المصدر
//
// تُضاف هذه الحقول لجدول ShowroomUser وCar
// عبر Prisma migration منفصلة عند البناء
//
// ShowroomUser — حقول نفاذ:
//   nationalId           String?   @unique
//   idType               String?   // citizen | resident | visitor
//   idIssueDate          String?   // Hijri
//   idExpiryDate         String?   // Hijri
//   nafathVerified       Boolean   @default(false)
//   nafathVerifiedAt     DateTime?
//   nafathRawData        Json?     // البيانات الخام من JWT نفاذ
//
// Car — حقول VDM (أبشر):
//   dataSource           CarDataSource @default(MANUAL)
//   vdmSequenceNumber    String?   // رقم التسلسل — يُستخدم في Accidents + Mojaz
//   vdmLastSyncAt        DateTime?
//   vdmRawData           Json?
//   registrationExpiry   DateTime? // انتهاء الاستمارة
//   inspectionExpiry     DateTime? // انتهاء الفحص
//   insuranceExpiry      DateTime? // انتهاء التأمين
//   insuranceCompany     String?
//   insurancePolicyNo    String?
//   engineSize           String?
//
// Car — حقول موجز:
//   mojazRequestId       String?   // requestId → لجلب PDF لاحقاً
//   mojazLastReportAt    DateTime? // تاريخ آخر تقرير
//   mojazReportUrl       String?   // رابط PDF المخزّن في R2
//   mojazRawData         Json?     // بيانات موجز الخام
//
// Car — حقول الحوادث (علم/بشر):
//   accidentsLastCheckAt DateTime?
//   accidentsCount       Int?      // آخر عدد محقَّق
//   accidentsCheckYears  Int?      // عدد السنوات في آخر استعلام

// ─── KYC Status Enum ──────────────────────────

enum KycStatus {
  NONE
  PENDING     // رُفعت المستندات — بانتظار المراجعة
  APPROVED    // موثّق
  REJECTED    // مرفوض — يحتاج إعادة رفع
}

// ─── Profile Completion Fields ────────────────
// تُضاف لـ ShowroomUser عبر migration
//
// نفاذ:
//   nationalId           String?  @unique
//   idType               String?   // citizen | resident | visitor
//   idExpiryDate         String?
//   nafathVerified       Boolean  @default(false)
//   nafathVerifiedAt     DateTime?
//   nafathRawData        Json?
//
// KYC يدوي:
//   kycStatus            KycStatus @default(NONE)
//   kycSubmittedAt       DateTime?
//   kycApprovedAt        DateTime?
//   kycDocFront          String?   // مسار R2
//   kycDocBack           String?
//   kycRejectReason      String?
//
// معلومات شخصية:
//   city                 String?
//   dateOfBirth          String?   // Hijri
//   phoneVerified        Boolean   @default(false)
//   phoneVerifiedAt      DateTime?
//
// بيانات المعرض/الشركة (على Showroom):
//   activityType         String?   // showroom | agency | hall
//   district             String?
//   instagramUrl         String?
//   commercialRegDoc     String?   // مسار R2
//   commercialRegVerified Boolean  @default(false)

// ─── Auction Fields (on Car) ──────────────────
// تُضاف لجدول Car عبر migration
// displayMode           String?   // FIXED_PRICE | SOUM | AUCTION
// minAcceptedPrice      Decimal?  @db.Decimal(12,2)   // سري
// auctionType           AuctionType?
// auctionSlug           String?   @unique             // للمزاد الخاص
// auctionStartAt        DateTime?
// auctionEndsAt         DateTime?
// auctionOpeningPrice   Decimal?  @db.Decimal(12,2)
// auctionBuyNowPrice    Decimal?  @db.Decimal(12,2)   // سعر الشراء الفوري
// auctionDepositAmount  Decimal?  @db.Decimal(10,2)   // عربون المزايدة

// ─── Bid (المزايدات) ──────────────────────────

model Bid {
  id         String   @id @default(uuid())
  carId      String
  bidderId   String
  showroomId String?
  amount     Decimal  @db.Decimal(12,2)
  isWinning  Boolean  @default(false)
  createdAt  DateTime @default(now())

  car     Car          @relation(fields: [carId], references: [id])
  bidder  ShowroomUser @relation(fields: [bidderId], references: [id])

  @@index([carId, amount])
  @@index([carId, createdAt])
  @@map("bids")
}

// ─── Plans (dynamic, admin-managed) ──────────

model Plan {
  id           String   @id @default(uuid())
  name         String
  nameAr       String
  slug         String   @unique  // starter | growth | pro | enterprise
  description  String?
  descriptionAr String?
  priceMonthly Decimal  @db.Decimal(10, 2)
  priceYearly  Decimal  @db.Decimal(10, 2)
  maxCars      Int?                           // null = unlimited
  // JSON: { market, auctions, api, reports, support, customShowroom }
  features     Json     @default("{}")
  isActive     Boolean  @default(true)
  isPublic     Boolean  @default(true)       // false = Enterprise (custom pricing)
  isFeatured   Boolean  @default(false)      // "موصى بها" badge
  sortOrder    Int      @default(0)
  trialDays    Int      @default(14)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

// ─── Subscriptions ────────────────────────────

model Subscription {
  id                 String             @id @default(uuid())
  showroomId         String             @unique
  planId             String
  status             SubscriptionStatus @default(TRIAL)
  billingPeriod      BillingPeriod      @default(MONTHLY)
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelledAt        DateTime?
  tapCustomerId      String?
  tapCardId          String?            // saved card token
  autoRenew          Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  showroom Showroom     @relation(fields: [showroomId], references: [id])
  plan     Plan         @relation(fields: [planId], references: [id])
  payments TapPayment[]

  @@map("subscriptions")
}

// ─── Tap Payments ─────────────────────────────

model TapPayment {
  id             String   @id @default(uuid())
  subscriptionId String
  tapChargeId    String   @unique
  amount         Decimal  @db.Decimal(10, 2)
  currency       String   @default("SAR")
  status         String   // INITIATED | CAPTURED | FAILED | REFUNDED
  description    String?
  tapResponse    Json?    // raw Tap response
  failureReason  String?
  paidAt         DateTime?
  createdAt      DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId, createdAt])
  @@map("tap_payments")
}

// ─── Platform Settings (key-value) ───────────

model PlatformSetting {
  key       String   @id
  value     String
  isSecret  Boolean  @default(false)
  updatedBy String?
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}
